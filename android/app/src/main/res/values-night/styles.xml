<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- I use this theme while the app is starting (when Dark Mode is ON). -->
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <!-- I show a splash screen here, and it goes away once Flutter draws
             the first frame. -->
        <item name="android:windowBackground">@drawable/launch_background</item>
    </style>
    <!-- I switch to this theme right after the app starts.
         It controls the window background while Flutter is loading and also
         behind the UI while it’s running.

         This is for Flutter’s Android embedding v2. -->
    <style name="NormalTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">?android:colorBackground</item>
    </style>
</resources>
